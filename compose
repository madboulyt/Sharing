# YAML Anchors for reusable configurations
x-tpm-devices: &tpm-devices
  devices:
    - /dev/tpmrm0
    - /dev/tpm0
  group_add:
    - "108"
    - "1000"

services:

  service-layout:
    build:
      context: .
      dockerfile: serving/models_servers/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_models:${VERSION_MODELS}
    environment:
      - LAYOUT_MODEL_PORT=${LAYOUT_MODEL_PORT}
      - CUDA_DEVICE_ORDER=PCI_BUS_ID # IMPORTANT: DO not renumber the GPUs
      - PYTHONWARNINGS=ignore::FutureWarning
    networks:
      - models-network
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
    deploy:
      replicas: ${ENABLE_LAYOUT_MODEL:-1}
      resources:
        reservations:
          devices:
            - driver: nvidia
              capabilities: [gpu]
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://service-layout:${LAYOUT_MODEL_PORT}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    command: >
      python -c 'from server_detection import main; main()'   
        --port ${LAYOUT_MODEL_PORT}
        --config $CONFIG_PATH_IMG
        --mode layout


  service-line:
    build:
      context: .
      dockerfile: serving/models_servers/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_models:${VERSION_MODELS}
    environment:
      - LINE_MODEL_PORT=${LINE_MODEL_PORT}
      - CUDA_DEVICE_ORDER=PCI_BUS_ID # IMPORTANT: DO not renumber the GPUs
      - PYTHONWARNINGS=ignore::FutureWarning
    networks:
      - models-network
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
    deploy:
      replicas: ${ENABLE_LINE_MODEL:-1}
      resources:
        reservations:
          devices:
            - driver: nvidia
              capabilities: [gpu]
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://service-line:${LINE_MODEL_PORT}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    command: >
      python -c 'from server_detection import main; main()'   
      --port ${LINE_MODEL_PORT}
      --config $CONFIG_PATH_IMG
      --mode line


  service-textrec:
    build:
      context: .
      dockerfile: serving/models_servers/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_models:${VERSION_MODELS}
    environment:
      - TEXTREC_PORT=${TEXTREC_PORT}
      - CUDA_DEVICE_ORDER=PCI_BUS_ID # IMPORTANT: DO not renumber the GPUs
    networks:
      - models-network
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
    deploy:
      replicas: ${ENABLE_TEXTREC_MODEL:-1}
      resources:
        reservations:
          devices:
            - driver: nvidia
              capabilities: [gpu]
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://service-textrec:${TEXTREC_PORT}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    command: >
      python -c 'from server_text import main; main()' 
      --port ${TEXTREC_PORT}
      --config $CONFIG_PATH_IMG



  vision-model:
    build:
      context: .
      dockerfile: serving/models_servers/vision_model/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_vision:${VERSION_PIPELINE}
    environment:
      - CUDA_DEVICE_ORDER=PCI_BUS_ID
    networks:
      - models-network
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
      - ${HF_CACHE_PATH:-/root/.cache/huggingface}:/root/.cache/huggingface
    deploy:
      replicas: ${ENABLE_VISION_MODEL:-1}
      resources:
        reservations:
          devices:
            - driver: nvidia
              capabilities: [gpu]
    shm_size: 16g
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://vision-model:${VISION_MODEL_PORT}/health"]
      interval: 30s
      timeout: 100s
      retries: 3
      start_period: 600s
    command: >
      --config $CONFIG_PATH_IMG
      --port ${VISION_MODEL_PORT}


  chart-detection:
    build:
      context: .
      dockerfile: serving/models_servers/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_models:${VERSION_MODELS}
    environment:
      - CHART_DETECTION_PORT=${CHART_DETECTION_PORT}
      - CUDA_DEVICE_ORDER=PCI_BUS_ID
      # server_chart_detection.so does `from chart_detection_security import ...`
      # (sibling import). When invoked as `python -c 'from chart_detection.X import ...'`
      # only /src is on sys.path; put the package dir on PYTHONPATH so the
      # sibling .so module is findable.
      - PYTHONPATH=/src/chart_detection
    networks:
      - models-network
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
    deploy:
      replicas: ${ENABLE_CHART_MODEL:-0}
      resources:
        reservations:
          devices:
            - driver: nvidia
              capabilities: [gpu]
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://chart-detection:${CHART_DETECTION_PORT}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 120s
    command: >
      python -c 'from chart_detection.server_chart_detection import main; main()'
      --port ${CHART_DETECTION_PORT}
      --config $CONFIG_PATH_IMG


  service-pipeline:
    build:
      context: .
      dockerfile: serving/pipeline_and_ui/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_pipeline:${VERSION_PIPELINE}
    environment:
      - LICENSE_FILE=/data/license.json
      - SIG_FILE=/data/license.sig
      - VENDOR_PUB=/data/vendor_pub.pem
      - RATE_LIMIT_HANDLER=${RATE_LIMIT_HANDLER}
      - OTEL_LOGS_ENDPOINT=${OTEL_LOGS_ENDPOINT}
      - USE_TABLES=${USE_TABLES:-false}
      - USE_CHARTS=${USE_CHARTS:-false}
    networks:
      - models-network
      - dps-test-network-cube_test
    <<: *tpm-devices
    ports:
      - "${PIPELINE_PORT}:${PIPELINE_PORT}"
    volumes:
      - ${CHECKPOINTS_PATH_HOST}:$CHECKPOINT_PATH_IMG
      - /home/data/cube_test_env/directories/license-data:/data
    stop_grace_period: 30s
    healthcheck:
      test: ["CMD", "curl", "-f", "http://service-pipeline:${PIPELINE_PORT}/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s
    command: >
      python -c 'from server_orchestrator import main; main()' 
        --port ${PIPELINE_PORT}
        --config $CONFIG_PATH_IMG
        --url_layout_service=http://service-layout:${LAYOUT_MODEL_PORT}
        --url_line_service=http://service-line:${LINE_MODEL_PORT}
        --url_textrec_service=http://service-textrec:${TEXTREC_PORT}
        --url_vision_service=http://vision-model:${VISION_MODEL_PORT}
        --url_chart_detection_service=http://chart-detection:${CHART_DETECTION_PORT}
    # No hard depends_on — model containers are optional (controlled by
    # ENABLE_*_MODEL flags).  The pipeline starts independently; workers
    # for disabled services simply have empty queues or return errors.

  ui:
    build:
      context: .
      dockerfile: serving/pipeline_and_ui/Dockerfile
    image: ${COMPOSE_PROJECT_NAME}_pipeline:${VERSION_PIPELINE}
    environment:
      - PIPELINE_SERVER_URL=http://service-pipeline:${PIPELINE_PORT}
      - JWT_TOK=${JWT_TOK}
    networks:
      - models-network
    ports:
      - "${UI_PORT}:${UI_PORT}"
    command: >
      streamlit run di_ui_app.py 
        --server.port ${UI_PORT} 
        --server.address 0.0.0.0


networks:
  models-network:
  dps-test-network-cube_test:
    external: true
volumes:
  pdf_files_v2:
    



